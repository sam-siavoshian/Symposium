    "ai-agents",
    "multi-agent",
    "research-engine",
    "llm",
    "nia",
    "code-generation",
    "training-data",
    "fine-tuning",
    "dpo",
    "terminal-bench",
    "benchmark",
    "developer-tools"
  ],
  "homepage": "https://github.com/sam-siavoshian/Symposium",
  "repository": {
    "type": "git",
    "url": "https://github.com/sam-siavoshian/Symposium.git"
  },
  "bugs": {
    "url": "https://github.com/sam-siavoshian/Symposium/issues"
  },
  "author": {
    "name": "Saam Siavoshian",
    "email": "samsiavoshian2009@gmail.com",
    "url": "https://x.com/samsiavoshian"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
